# ============================================================
# PRODUCTION ENVIRONMENT — copy to .env and fill all values
# NEVER commit the actual .env file
# ============================================================

NODE_ENV=production
PORT=3001

# Database (use a strong password, never the default)
DATABASE_URL=postgresql://postgres:STRONG_PASSWORD@postgres:5432/imposter_game

# Redis (set a password in production)
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379

# JWT — MUST be at least 32 random characters
# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Your app public URL
APP_URL=https://yourdomain.com

# Google OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In (optional — leave empty to disable)
APPLE_CLIENT_ID=com.yourcompany.appname
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Stripe (optional — leave empty to disable payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
