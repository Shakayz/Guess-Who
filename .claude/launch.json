{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API (Fastify)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@imposter/api", "dev"],
      "port": 3001
    },
    {
      "name": "Web (Vite)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@imposter/web", "dev"],
      "port": 5173
    },
    {
      "name": "Mobile (Expo)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@imposter/mobile", "dev"],
      "port": 8081
    },
    {
      "name": "Dev Infrastructure (PostgreSQL + Redis)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "-f", "docker-compose.dev.yml", "up"],
      "port": 5432
    }
  ]
}
